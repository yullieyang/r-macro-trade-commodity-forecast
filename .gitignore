# R session / user state
.Rhistory
.Rapp.history
.RData
.Ruserdata
.Rproj.user/

# Local environment with secrets (FRED_API_KEY etc.)
.Renviron

# OS cruft
.DS_Store
Thumbs.db

# Raw FRED snapshots: large and trivially regenerated by 01_get_data.R,
# so we exclude the bytes but keep the directory.
data/raw/*
!data/raw/.gitkeep

# Processed data and generated outputs ARE committed so the GitHub page
# renders figures and so reviewers can inspect artifacts without running R.

# Quarto render output (deployed to gh-pages by Actions, not committed to main)
/_site/
/.quarto/
